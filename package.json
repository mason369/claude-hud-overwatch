{
  "name": "claude-hud-overwatch",
  "version": "0.0.12",
  "description": "Claude Code 全视状态栏 — 全功能默认开启、Hook 防护监控、违规检测、子代理追踪（中文优先）",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "commands/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "benchmark": "node benchmark/run-benchmark.js",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 npm test",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"Opus\"},\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"transcript_path\":\"/tmp/test.jsonl\"}' | node dist/index.js"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "hud",
    "overwatch",
    "hooks",
    "monitoring",
    "chinese"
  ],
  "author": "Jarrod Watts (fork by claude-hud-overwatch contributors)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mason369/claude-hud-overwatch"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "typescript": "^6.0.2"
  }
}
